{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      ".read": "auth != null",
      "$pid": {
        ".write": "auth != null && ((newData.exists() && newData.child('owner').val() === auth.uid) || (!newData.exists() && data.exists() && (data.child('owner').val() === auth.uid || data.child('t').val() < now - 600000)))",
        ".validate": "newData.hasChildren(['owner', 'name', 'lat', 'lng', 't', 'hue', 'acc'])",
        "owner": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 24"
        },
        "lat": {
          ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
        },
        "lng": {
          ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
        },
        "acc": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000"
        },
        "hue": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 360"
        },
        "t": {
          ".validate": "newData.isNumber() && newData.val() === now"
        },
        "$other": { ".validate": false }
      }
    }
  }
}
